# Kinshout API (api/Kinshout.Api/appsettings or hosting env)
ClientAuth__KinshoutWebSecret=your-strong-random-secret-here

# OpenAI (categorize, search, image moderation). ASP.NET maps OpenAI__ApiKey → OpenAI:ApiKey.
# Local: dotnet user-secrets set "OpenAI:ApiKey" "sk-proj-..." --project api/Kinshout.Api
# Or export before `dotnet run`:
OpenAI__ApiKey=sk-proj-your-key-here
OpenAI__Model=gpt-4o-mini
OpenAI__ModerationEnabled=false

# Frontend (browser — set via window globals or Vite env at build time)
# VITE_KINSHOUT_API=https://your-kinshout-api.example.com
# VITE_KINSHOUT_CLIENT_ID=kinshout-web
# VITE_KINSHOUT_CLIENT_SECRET=your-strong-random-secret-here
# VITE_FACEBOOK_APP_ID=your-meta-app-id

# Or in index.html before api-client.js:
# <script>
#   window.KINSHOUT_API = "https://your-kinshout-api.example.com";
#   window.KINSHOUT_CLIENT_ID = "kinshout-web";
#   window.KINSHOUT_CLIENT_SECRET = "your-strong-random-secret-here";
# </script>
